{
  "_comment": "Maps Lean declarations to LaTeX labels, PDF sections, and descriptions",
  "_usage": "Dashboard uses this for display. Keep in sync with Basic.lean.",

  "mappings": {
    "Scalar": {"description": "Scalar field (ℝ)", "group": "Scalar Field"},
    "Scalar.zero": {"description": "Additive identity 0", "group": "Scalar Field"},
    "Scalar.one": {"description": "Multiplicative identity 1", "group": "Scalar Field"},
    "Scalar.add": {"description": "Addition a + b", "group": "Scalar Field"},
    "Scalar.mul": {"description": "Multiplication a × b", "group": "Scalar Field"},
    "Scalar.neg": {"description": "Negation -a", "group": "Scalar Field"},
    "Scalar.le": {"description": "Order ≤ on scalars", "group": "Scalar Field"},
    "Scalar.add_comm": {"description": "a + b = b + a", "group": "Scalar Field"},
    "Scalar.add_assoc": {"description": "(a + b) + c = a + (b + c)", "group": "Scalar Field"},
    "Scalar.add_zero": {"description": "a + 0 = a", "group": "Scalar Field"},
    "Scalar.zero_add": {"description": "0 + a = a", "group": "Scalar Field"},
    "Scalar.add_neg": {"description": "a + (-a) = 0", "group": "Scalar Field"},
    "Scalar.neg_add": {"description": "(-a) + a = 0", "group": "Scalar Field"},
    "Scalar.mul_comm": {"description": "a × b = b × a", "group": "Scalar Field"},
    "Scalar.mul_assoc": {"description": "(a × b) × c = a × (b × c)", "group": "Scalar Field"},
    "Scalar.mul_one": {"description": "a × 1 = a", "group": "Scalar Field"},
    "Scalar.one_mul": {"description": "1 × a = a", "group": "Scalar Field"},
    "Scalar.zero_mul": {"description": "0 × a = 0", "group": "Scalar Field"},
    "Scalar.mul_zero": {"description": "a × 0 = 0", "group": "Scalar Field"},
    "Scalar.distrib_left": {"description": "a × (b + c) = ab + ac", "group": "Scalar Field"},
    "Scalar.distrib_right": {"description": "(a + b) × c = ac + bc", "group": "Scalar Field"},
    "Scalar.neg_one_mul": {"description": "(-1) × a = -a", "group": "Scalar Field"},
    "Scalar.neg_neg": {"description": "-(-a) = a", "group": "Scalar Field"},
    "Scalar.zero_le_self_mul_self": {"description": "0 ≤ a²", "group": "Scalar Field"},
    "Scalar.ofNat": {"description": "Coercion ℕ → Scalar", "group": "Scalar Field"},
    "Scalar.ofNat_zero": {"description": "ofNat 0 = 0", "group": "Scalar Field"},
    "Scalar.ofNat_succ": {"description": "ofNat (n+1) = ofNat n + 1", "group": "Scalar Field"},

    "H": {"description": "Hilbert space", "group": "Vector Space", "latex_label": "def:vector-space"},
    "H.zero": {"description": "Zero vector", "group": "Vector Space"},
    "H.add": {"description": "Vector addition x + y", "group": "Vector Space"},
    "H.neg": {"description": "Vector negation -x", "group": "Vector Space"},
    "H.smul": {"description": "Scalar multiplication a·x", "group": "Vector Space"},
    "H.sub": {"description": "Subtraction x - y := x + (-y)", "group": "Vector Space"},
    "H.add_comm": {"description": "x + y = y + x", "group": "Vector Space"},
    "H.add_assoc": {"description": "(x + y) + z = x + (y + z)", "group": "Vector Space"},
    "H.add_zero": {"description": "x + 0 = x", "group": "Vector Space"},
    "H.zero_add": {"description": "0 + x = x", "group": "Vector Space"},
    "H.add_neg": {"description": "x + (-x) = 0", "group": "Vector Space"},
    "H.neg_add": {"description": "(-x) + x = 0", "group": "Vector Space"},
    "H.smul_one": {"description": "1·x = x", "group": "Vector Space"},
    "H.smul_assoc": {"description": "a·(b·x) = (ab)·x", "group": "Vector Space"},
    "H.smul_distrib_scalar": {"description": "(a+b)·x = a·x + b·x", "group": "Vector Space"},
    "H.smul_distrib_vector": {"description": "a·(x + y) = a·x + a·y", "group": "Vector Space"},
    "H.neg_smul": {"description": "(-1)·x = -x", "group": "Vector Space"},
    "H.zero_smul": {"description": "0·x = 0", "group": "Vector Space"},

    "inner": {"description": "Inner product ⟨x, y⟩", "group": "Inner Product", "latex_label": "def:inner-product"},
    "inner_comm": {"description": "⟨x, y⟩ = ⟨y, x⟩ (symmetry)", "group": "Inner Product"},
    "inner_add_left": {"description": "⟨x + y, z⟩ = ⟨x, z⟩ + ⟨y, z⟩", "group": "Inner Product"},
    "inner_smul_left": {"description": "⟨a·x, y⟩ = a·⟨x, y⟩", "group": "Inner Product"},
    "inner_self_nonneg": {"description": "⟨x, x⟩ ≥ 0", "group": "Inner Product"},
    "inner_self_eq_zero": {"description": "⟨x, x⟩ = 0 ↔ x = 0", "group": "Inner Product"},
    "inner_add_right": {"description": "⟨x, y + z⟩ = ⟨x, y⟩ + ⟨x, z⟩", "group": "Inner Product"},
    "inner_neg_left": {"description": "⟨-x, y⟩ = -⟨x, y⟩", "group": "Inner Product"},
    "inner_neg_right": {"description": "⟨x, -y⟩ = -⟨x, y⟩", "group": "Inner Product"},
    "inner_smul_right": {"description": "⟨x, a·y⟩ = a·⟨x, y⟩", "group": "Inner Product"},
    "normSq": {"description": "Squared norm ||x||² = ⟨x, x⟩", "group": "Inner Product"},

    "H.sub_eq_add_neg": {"description": "x - y = x + (-y)", "group": "Derived Algebra"},
    "H.add_add_add_comm": {"description": "(a+b)+(c+d) = (a+c)+(b+d)", "group": "Derived Algebra"},
    "H.smul_add_symm": {"description": "a·x + a·y = a·(x+y)", "group": "Derived Algebra"},
    "H.neg_add_distrib": {"description": "-(x + y) = -x + -y", "group": "Derived Algebra"},
    "H.smul_neg": {"description": "a·(-x) = -(a·x)", "group": "Derived Algebra"},
    "H.neg_zero": {"description": "-0 = 0", "group": "Derived Algebra"},
    "H.neg_neg": {"description": "-(-x) = x", "group": "Derived Algebra"},
    "H.add_neg_cancel_right": {"description": "(x + y) + (-y) = x", "group": "Derived Algebra"},
    "H.neg_add_cancel_left": {"description": "(-x) + (x + y) = y", "group": "Derived Algebra"},
    "H.add_cancel_grouped": {"description": "(a+b)+(c+d)-a = b+(c+d)", "group": "Derived Algebra"},
    "H.leibniz_cancel": {"description": "(a+(-b))+(c+(-a)) = c+(-b)", "group": "Derived Algebra"},

    "LinOp": {"description": "Bounded linear operator A: H → H", "group": "Operators"},
    "LinOp.id": {"description": "Identity operator I", "group": "Operators"},
    "LinOp.comp": {"description": "Composition (A ∘ B)(x) = A(B(x))", "group": "Operators"},
    "LinOp.add": {"description": "Operator addition (A + B)(x) = Ax + Bx", "group": "Operators"},
    "LinOp.adjoint": {"description": "Adjoint operator A†", "group": "Operators"},
    "LinOp.adjoint_spec": {"description": "⟨Ax, y⟩ = ⟨x, A†y⟩", "group": "Operators"},
    "LinOp.map_neg": {"description": "A(-x) = -(A x)", "group": "Operators"},

    "OrthProj": {"description": "Orthogonal projection (P² = P, P* = P)", "group": "Projections", "latex_label": "def:horizon-tower"},
    "OrthProj.ran": {"description": "Range of P: {x : Px = x}", "group": "Projections"},
    "OrthProj.shadow": {"description": "Shadow projection Π̄ = I - Π", "group": "Projections", "latex_label": "def:shadow-projector"},
    "OrthProj.proj_shadow_orthog": {"description": "⟨Px, (I-P)x⟩ = 0", "group": "Projections"},
    "pythagorean_splitting": {"description": "||x||² = ||Πx||² + ||Π̄x||²", "group": "Projections", "latex_label": "lem:pythagorean-splitting"},

    "HorizonTower": {"description": "Nested projections Π_h with transitivity", "group": "Horizon Tower", "latex_label": "def:horizon-tower"},
    "HorizonTower.trans": {"description": "Π_h Π_{h'} = Π_h for h ≤ h'", "group": "Horizon Tower"},
    "HorizonTower.trans_right": {"description": "Π_{h'} Π_h = Π_h for h ≤ h'", "group": "Horizon Tower"},
    "HorizonTower.Obs": {"description": "Observable subspace at horizon h", "group": "Horizon Tower"},
    "HorizonTower.Sh": {"description": "Shadow subspace at horizon h", "group": "Horizon Tower"},
    "HorizonTower.increment": {"description": "Increment Δ_h = Π_h - Π_{h-1}", "group": "Horizon Tower"},
    "HorizonTower.increment_zero": {"description": "Δ_0 = Π_0", "group": "Horizon Tower"},
    "HorizonTower.proj_increment": {"description": "Π_h Δ_k = Δ_k for k ≤ h", "group": "Horizon Tower"},
    "HorizonTower.telescope_step": {"description": "Π_{n+1} = Π_n + Δ_{n+1}", "group": "Horizon Tower"},
    "HorizonTower.proj_selfadj": {"description": "⟨Π_h x, y⟩ = ⟨Π_h y, x⟩", "group": "Horizon Tower"},
    "HorizonTower.increment_orthog_lt": {"description": "⟨Δ_h x, Δ_k y⟩ = 0 for h < k", "group": "Horizon Tower", "latex_label": "lem:orthogonal-telescoping"},
    "HorizonTower.increment_orthog_gt": {"description": "⟨Δ_k x, Δ_h y⟩ = 0 for h < k", "group": "Horizon Tower"},
    "HorizonTower.increment_orthog": {"description": "⟨Δ_h x, Δ_k y⟩ = 0 for h ≠ k", "group": "Horizon Tower", "latex_label": "lem:orthogonal-telescoping"},
    "HorizonTower.increment_idem": {"description": "Δ_h² = Δ_h (increment is projection)", "group": "Horizon Tower"},
    "HorizonTower.increment_selfadj": {"description": "⟨Δ_h x, y⟩ = ⟨x, Δ_h y⟩", "group": "Horizon Tower"},
    "HorizonTower.increment_selfadj_symm": {"description": "⟨Δ_h x, y⟩ = ⟨Δ_h y, x⟩", "group": "Horizon Tower"},

    "resolution_of_identity": {"description": "x = Px + (I-P)x", "group": "Foundational Lemmas", "latex_label": "lem:resolution-identity"},
    "single_cut_right": {"description": "Ax = A(Px) + A((I-P)x)", "group": "Foundational Lemmas", "latex_label": "lem:resolution-identity"},
    "single_cut_left": {"description": "Ax = P(Ax) + (I-P)(Ax)", "group": "Foundational Lemmas", "latex_label": "lem:resolution-identity"},
    "double_cut": {"description": "A = ΠAΠ + ΠAΠ̄ + Π̄AΠ + Π̄AΠ̄", "group": "Foundational Lemmas", "latex_label": "lem:resolution-identity"},
    "block_splitting": {"description": "Π(AB)Π = (ΠAΠ)(ΠBΠ) + ΠAΠ̄BΠ", "group": "Foundational Lemmas", "latex_label": "lem:block-splitting"},
    "leakageCorrection": {"description": "Leakage correction ΠAΠ̄BΠ", "group": "Foundational Lemmas"},
    "squared_block_splitting": {"description": "Π(A²)Π = (ΠAΠ)² + ΠAΠ̄AΠ", "group": "Foundational Lemmas", "latex_label": "lem:block-splitting"},
    "operator_action_splitting": {"description": "||Ax||² = ||Π(Ax)||² + ||Π̄(Ax)||²", "group": "Foundational Lemmas", "latex_label": "lem:pythagorean-splitting"},
    "observed_leakage_splitting": {"description": "||Ax||² = ||(ΠAΠ)x||² + ||(Π̄AΠ)x||²", "group": "Foundational Lemmas", "latex_label": "lem:pythagorean-splitting"},

    "NilpotentDiff": {"description": "Differential d with d² = 0", "group": "Nilpotent Differential", "latex_label": "def:nilpotent-differential"},

    "observedOp": {"description": "Observed operator d_h = Π_h d Π_h", "group": "Observed/Leakage", "latex_label": "def:observed-operator"},
    "observedOp_idem": {"description": "Π(d_h x) = d_h x (observed stays observed)", "group": "Observed/Leakage"},
    "leakageOp": {"description": "Leakage B_h = Π̄_h d Π_h", "group": "Observed/Leakage", "latex_label": "def:leakage-operator"},
    "leakage_orthog_to_obs": {"description": "⟨d_h x, B_h x⟩ = 0", "group": "Observed/Leakage"},

    "defectOp": {"description": "Defect δ_h = Π_h d Π̄_h d Π_h", "group": "Defect", "latex_label": "def:defect-operator"},
    "defectEnergy": {"description": "Defect energy Γ_h(x) = ⟨x, δ_h x⟩", "group": "Defect"},
    "nilpotent_resolution": {"description": "d(d_h x) + d(B_h x) = 0", "group": "Defect"},
    "defect_from_nilpotent": {"description": "d_h² = -δ_h (for nilpotent d)", "group": "Defect"},

    "coherenceDefect": {"description": "τ_h(F;x) = Π F(x) - F(Πx)", "group": "Coherence Defect", "latex_label": "def:coherence-defect"},
    "coherenceDefect_linear": {"description": "τ_h(A;x) = ΠAx - AΠx for linear A", "group": "Coherence Defect"},
    "zero_defect_iff_commutes": {"description": "τ = 0 ⟺ Π and A commute", "group": "Coherence Defect"},
    "chain_rule": {"description": "τ(F∘G;x) = τ(F;Gx) + mismatch", "group": "Coherence Defect", "latex_label": "prop:chain-rule"},

    "bilinearDefect": {"description": "τ₂(B;x,y) = Π B(x,y) - B(Πx, Πy)", "group": "Coherence Defect", "latex_label": "def:bilinear-defect"},
    "Bilinear": {"description": "Bilinear map B: H × H → H", "group": "Coherence Defect"},
    "product_rule": {"description": "τ₂ = cross-term decomposition", "group": "Coherence Defect", "latex_label": "prop:product-rule"},

    "scaleIndexOp": {"description": "Scale index operator N = Σ_h h·Δ_h", "group": "Tower Calculus"},
    "scaleIndex_on_layer": {"description": "N(Δ_k x) = k·Δ_k x (eigenvalue)", "group": "Tower Calculus"},
    "towerDeriv": {"description": "Tower derivative ∂(A) = [N, A]", "group": "Tower Calculus"},
    "towerDeriv_id": {"description": "∂(I) = 0", "group": "Tower Calculus"},
    "towerDeriv_comp": {"description": "∂(AB) = A·∂(B) + ∂(A)·B (Leibniz)", "group": "Tower Calculus"},

    "blockPP": {"description": "Block P→P: A_PP = PAP", "group": "Block Components", "latex_label": "def:block-components"},
    "blockPQ": {"description": "Block Q→P: A_PQ = PAQ", "group": "Block Components", "latex_label": "def:block-components"},
    "blockQP": {"description": "Block P→Q: A_QP = QAP (Leakage)", "group": "Block Components", "latex_label": "def:block-components"},
    "blockQQ": {"description": "Block Q→Q: A_QQ = QAQ", "group": "Block Components", "latex_label": "def:block-components"},
    "block_decomposition": {"description": "A = A_PP + A_PQ + A_QP + A_QQ", "group": "Block Components", "latex_label": "def:block-components"},
    "blockPP_eq_observedOp": {"description": "A_PP = observedOp", "group": "Block Components"},
    "blockQP_eq_leakageOp": {"description": "A_QP = leakageOp", "group": "Block Components"},

    "shadowCommutator": {"description": "S(A) = [Π̄, A] = Π̄A - AΠ̄", "group": "Shadow Commutator", "latex_label": "sec:cross-block"},
    "observableCommutator": {"description": "[Π, A] = ΠA - AΠ", "group": "Shadow Commutator"},
    "commutator_sum_zero": {"description": "[Π, A] + [Π̄, A] = 0", "group": "Shadow Commutator"},
    "zero_shadow_comm_iff": {"description": "S(A) = 0 ⟺ A preserves shadow", "group": "Shadow Commutator"},

    "LinOp.inv": {"description": "Operator inverse A⁻¹", "group": "Schur Complement"},
    "LinOp.inv_left": {"description": "A⁻¹(Ax) = x", "group": "Schur Complement"},
    "LinOp.inv_right": {"description": "A(A⁻¹x) = x", "group": "Schur Complement"},
    "LinOp.sub": {"description": "Operator subtraction A - B", "group": "Schur Complement"},
    "LinOp.scalarMul": {"description": "Scalar mult z·A", "group": "Schur Complement"},
    "resolvent": {"description": "R_A(z) = (I - zA)⁻¹", "group": "Schur Complement", "latex_label": "def:resolvent"},
    "schurCorrection": {"description": "Σ(z) = A_PQ (I - z A_QQ)⁻¹ A_QP", "group": "Schur Complement", "latex_label": "def:schur-correction"},
    "effectiveOp": {"description": "A_eff(z) = A_PP + z Σ(z)", "group": "Schur Complement", "latex_label": "def:effective-operator"},

    "HorizonTower.horizonFlow": {"description": "∇_h A = A_h - A_{h-1}", "group": "Horizon Flow", "latex_label": "subsec:horizon-flow"},
    "HorizonTower.horizonFlow_zero": {"description": "∇_0 A = A_0", "group": "Horizon Flow"},
    "HorizonTower.horizonFlow_succ": {"description": "∇_{h+1} A = A_{h+1} - A_h", "group": "Horizon Flow"},

    "HorizonTrace": {"description": "Tr_h(A) = Tr(Π_h A)", "group": "Trace", "latex_label": "subsec:coherence-trace"},
    "HorizonTrace.linear": {"description": "Tr_h(A + B) = Tr_h(A) + Tr_h(B)", "group": "Trace"},
    "HorizonTrace.smul": {"description": "Tr_h(zA) = z·Tr_h(A)", "group": "Trace"},
    "tower_trace_telescoping": {"description": "Tr_h = Σ layer traces", "group": "Trace", "latex_label": "subsec:tower-trace-telescoping"},
    "HorizonTrace.monotone": {"description": "Tr_h ≤ Tr_{h'} for h ≤ h' (PSD)", "group": "Trace"},

    "defectEnergyOp": {"description": "L_h = B_h† B_h (PSD)", "group": "Coherence Gap", "latex_label": "sec:coherence-gap"},
    "defect_energy_nonneg": {"description": "⟨x, L_h x⟩ ≥ 0", "group": "Coherence Gap"},
    "perfect_coherence": {"description": "⟨x, L_h x⟩ = 0 ⟹ ||B_h x||² = 0", "group": "Coherence Gap"},

    "IdempOp": {"description": "Idempotent E² = E (oblique proj)", "group": "Oblique Projections", "latex_label": "sec:oblique"},
    "IdempOp.comp": {"description": "Complement 𝟙 - E", "group": "Oblique Projections"},
    "oblique_resolution": {"description": "x = Ex + (𝟙-E)x", "group": "Oblique Projections"},
    "obliqueObs": {"description": "E A E (oblique observed)", "group": "Oblique Projections"},
    "obliqueLeak": {"description": "(𝟙-E) A E (oblique leakage)", "group": "Oblique Projections"},
    "obliqueDefect": {"description": "E A (𝟙-E) A E (oblique defect)", "group": "Oblique Projections"},

    "HorizonTower.increment_orthog_proj": {"description": "⟨Δ_h x, Δ_k y⟩ = 0 for h ≠ k", "group": "Layer Properties"},
    "HorizonTower.proj_increment_eq": {"description": "Π_h Δ_h = Δ_h", "group": "Layer Properties"},
    "HorizonTower.proj_increment_orthog": {"description": "⟨Π_h x, Δ_{h+1} y⟩ = 0", "group": "Layer Properties"},
    "HorizonTower.layer_norm_step": {"description": "||Π_{h+1} x||² = ||Π_h x||² + ||Δ_{h+1} x||²", "group": "Layer Properties"},

    "Scalar.sub": {"description": "Subtraction a - b = a + (-b)", "group": "Scalar Field"},
    "Scalar.sub_eq_add_neg": {"description": "a - b = a + (-b)", "group": "Scalar Field"},

    "SelfAdjointOp": {"description": "Self-adjoint operator (A* = A)", "group": "Spectral Theory"},
    "SelfAdjointOp.selfadj_symm": {"description": "⟨Ax, y⟩ = ⟨y, Ax⟩", "group": "Spectral Theory"},
    "SelfAdjointOp.inner_swap": {"description": "⟨x, Ay⟩ = ⟨Ax, y⟩", "group": "Spectral Theory"},
    "OrthProj.toSelfAdjoint": {"description": "Orthogonal projection is self-adjoint", "group": "Spectral Theory"},

    "SpectralSelector": {"description": "Q_S(A) = E_A(S) spectral projector", "group": "Spectral Theory"},
    "spectral_idem": {"description": "Q_S² = Q_S (spectral proj idempotent)", "group": "Spectral Theory"},
    "spectral_orthog": {"description": "Q_S ⊥ Q_T for disjoint S, T", "group": "Spectral Theory"},
    "spectral_inter": {"description": "Q_S Q_T = Q_{S∩T}", "group": "Spectral Theory"},
    "spectral_full": {"description": "Q_ℝ = I (full spectrum)", "group": "Spectral Theory"},
    "spectral_empty": {"description": "Q_∅ = 0 (empty spectrum)", "group": "Spectral Theory"},

    "resolvent_identity": {"description": "R(z) - R(w) = (z-w)R(z)R(w)", "group": "Resolvent"},
    "resolvent_series_leading": {"description": "R(0) = I (Neumann leading term)", "group": "Resolvent"},

    "OrthProj.le": {"description": "P₁ ≤ P₂ means P₁P₂ = P₁", "group": "Nested Projections"},
    "HorizonTower.proj_le": {"description": "Π_h ≤ Π_{h'} for h ≤ h'", "group": "Nested Projections"},
    "nested_proj_containment": {"description": "P₁ ≤ P₂ ⟹ P₂P₁ = P₁", "group": "Nested Projections"},
    "nested_schur_structure": {"description": "Nested Schur complement structure", "group": "Nested Projections"},

    "RepresentationProj": {"description": "P_ρ isotypic component projector", "group": "Representation Theory"},
    "rep_proj_orthog": {"description": "P_ρ ⊥ P_σ for inequivalent ρ, σ", "group": "Representation Theory"},
    "rep_proj_idem": {"description": "P_ρ² = P_ρ", "group": "Representation Theory"},

    "Monodromy": {"description": "Unitary monodromy operator M", "group": "Monodromy"},
    "Monodromy.preserves_norm": {"description": "⟨Mx, Mx⟩ = ⟨x, x⟩", "group": "Monodromy"},

    "InvariantFilter": {"description": "G_Γ averaging projector", "group": "Invariant Filters"},
    "invariant_filter_idem": {"description": "G_Γ² = G_Γ", "group": "Invariant Filters"},
    "invariant_filter_fixed": {"description": "G_Γ x = x for invariant x", "group": "Invariant Filters"},

    "HorizonEntropy": {"description": "S[P] horizon entropy", "group": "Horizon Entropy"},
    "entropy_nonneg": {"description": "S[P] ≥ 0", "group": "Horizon Entropy"},
    "entropy_monotone": {"description": "P₁ ≤ P₂ ⟹ S[P₁] ≤ S[P₂]", "group": "Horizon Entropy"},

    "observed_fixed": {"description": "P(observedOp x) = observedOp x", "group": "Coherence Identities"},
    "leakage_in_shadow": {"description": "P̄(leakage x) = leakage x", "group": "Coherence Identities"},
    "observed_leakage_sum": {"description": "observed + leakage = APx", "group": "Coherence Identities"},
    "observed_squared": {"description": "(obs)² = obs(A∘obs)", "group": "Coherence Identities"},
    "zero_defect_projection_preserving": {"description": "τ = 0 for [P,A] = 0", "group": "Coherence Identities"},
    "zero_leakage_commuting": {"description": "B = 0 for [P,A] = 0", "group": "Coherence Identities"},

    "HorizonTower.defect_leakage_relation": {"description": "δ = P A B (defect from leakage)", "group": "Defect Accumulation"},
    "HorizonTower.shadow_monotone": {"description": "Π̄_h Π̄_{h+1} = Π̄_{h+1}", "group": "Defect Accumulation"}
  }
}
