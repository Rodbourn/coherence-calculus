            localSlotReadout assembly'.readout assembly'.frame current' slot) →
          assembly.realizeCoordinates (data.exactifyIterate n current) =
            assembly'.realizeCoordinates (data.exactifyIterate n current') := by
  intro n current current' hslots
  apply assembly.sameCoordinates_acrossAssemblies_sameHiddenTrajectory assembly' n current current'
  exact assembledCoordinates_eq_of_localSlotReadout_eq hslots

