            assembly.realizeCoordinates current' →
          assembly.observedState (data.exactifyIterate n current) =
            assembly.observedState (data.exactifyIterate n current') := by
  intro n current current' hcoords
  calc
    assembly.observedState (data.exactifyIterate n current) =
        (data.reducedObservedSystem.observedIterate n)
          (assembly.realizeCoordinates current) :=
      assembly.systemObservedTrajectory n current
    _ =
        (data.reducedObservedSystem.observedIterate n)
          (assembly.realizeCoordinates current') :=
      data.reducedObservedSystem.observedIterate_congr n hcoords
    _ =
        assembly.observedState (data.exactifyIterate n current') := by
      symm
      exact assembly.systemObservedTrajectory n current'

/-- On one explicit detached current assembly, the reduced hidden trajectory
already depends only on the initial six local slot values. Once two initial
currents agree slot-by-slot on the framed pair carrier, their reduced hidden
trajectories agree at every step. -/
theorem CurrentStateAssembly.sameLocalSlots_sameHiddenTrajectory
    {Index Time Carrier Law : Type}
    {data : AnchoredCurrentObject Index Time Carrier Law}
    (assembly : CurrentStateAssembly data) :
    ∀ n : Nat,
      ∀ current current' : PairExchangeCurrent data.currentCarrier data.Leg,
        (∀ slot : LocalSlot,
          localSlotReadout assembly.readout assembly.frame current slot =
            localSlotReadout assembly.readout assembly.frame current' slot) →
          assembly.realizeCoordinates (data.exactifyIterate n current) =
            assembly.realizeCoordinates (data.exactifyIterate n current') := by
  intro n current current' hslots
  apply assembly.sameCoordinates_sameHiddenTrajectory n current current'
  exact assembledCoordinates_eq_of_localSlotReadout_eq hslots

/-- On one explicit detached current assembly, the selected observed trajectory
already depends only on the initial six local slot values. Once two initial
currents agree slot-by-slot on the framed pair carrier, their selected
observed trajectories agree at every step. -/
theorem CurrentStateAssembly.sameLocalSlots_sameObservedTrajectory
    {Index Time Carrier Law : Type}
    {data : AnchoredCurrentObject Index Time Carrier Law}
    (assembly : CurrentStateAssembly data) :
    ∀ n : Nat,
      ∀ current current' : PairExchangeCurrent data.currentCarrier data.Leg,
        (∀ slot : LocalSlot,
          localSlotReadout assembly.readout assembly.frame current slot =
            localSlotReadout assembly.readout assembly.frame current' slot) →
          assembly.observedState (data.exactifyIterate n current) =
            assembly.observedState (data.exactifyIterate n current') := by
  intro n current current' hslots
  apply assembly.sameCoordinates_sameObservedTrajectory n current current'
  exact assembledCoordinates_eq_of_localSlotReadout_eq hslots

/-- Two explicit detached current assemblies on the same anchored current
object induce the same hidden trajectory whenever they agree on the initial
reduced hidden coordinates. -/
theorem CurrentStateAssembly.sameCoordinates_acrossAssemblies_sameHiddenTrajectory
    {Index Time Carrier Law : Type}
    {data : AnchoredCurrentObject Index Time Carrier Law}
    (assembly assembly' : CurrentStateAssembly data) :
    ∀ n : Nat,
      ∀ current current' : PairExchangeCurrent data.currentCarrier data.Leg,
        assembly.realizeCoordinates current =
            assembly'.realizeCoordinates current' →
          assembly.realizeCoordinates (data.exactifyIterate n current) =
            assembly'.realizeCoordinates (data.exactifyIterate n current') := by
  intro n current current' hcoords
  calc
    assembly.realizeCoordinates (data.exactifyIterate n current) =
        (data.reducedObservedSystem.hiddenIterate n)
          (assembly.realizeCoordinates current) :=
      assembly.systemHiddenTrajectory n current
    _ =
        (data.reducedObservedSystem.hiddenIterate n)
          (assembly'.realizeCoordinates current') :=
      data.reducedObservedSystem.hiddenIterate_congr n hcoords
    _ =
        assembly'.realizeCoordinates (data.exactifyIterate n current') := by
      symm
      exact assembly'.systemHiddenTrajectory n current'

/-- Two explicit detached current assemblies on the same anchored current
object induce the same reduced hidden trajectory whenever their initial
framed pair currents agree slot-by-slot. The concrete readout/frame data are
therefore relevant only through the six local slot values they assign. -/
theorem CurrentStateAssembly.sameLocalSlots_acrossAssemblies_sameHiddenTrajectory
    {Index Time Carrier Law : Type}
    {data : AnchoredCurrentObject Index Time Carrier Law}
